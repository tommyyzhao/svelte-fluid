{
	"name": "svelte-fluid",
	"version": "0.1.0",
	"description": "WebGL fluid simulation as a Svelte 5 component. Multi-instance, resize-stable, deterministic seeding. Port of Pavel Dobryakov's WebGL-Fluid-Simulation.",
	"license": "MIT",
	"author": "Tommy Zhao (https://github.com/tommyyzhao)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tommyyzhao/svelte-fluid.git"
	},
	"homepage": "https://tommyyzhao.github.io/svelte-fluid/",
	"bugs": {
		"url": "https://github.com/tommyyzhao/svelte-fluid/issues"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && bun run prepack",
		"package": "svelte-kit sync && svelte-package",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": false,
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"engines": {
		"node": ">=18"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"publint": "^0.3.17",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.4"
	},
	"keywords": [
		"svelte",
		"svelte5",
		"webgl",
		"fluid",
		"simulation",
		"canvas",
		"shader",
		"navier-stokes"
	]
}
